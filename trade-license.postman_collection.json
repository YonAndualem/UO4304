{
  "info": {
    "_postman_id": "trade-license-workflow-v2",
    "name": "Trade License Workflow API (Current)",
    "description": "Updated collection for current API routes and JWT auth flow.\n\nQuick start:\n1. Run `Auth / Login Customer` (or reviewer/approver) to set token variables.\n2. Run `Customer / Submit Application` to set `app_id`.\n3. Use role folders with matching token variables.\n\nCollection variables:\n- base_url (default http://localhost:8080)\n- customer_id / customer_password\n- reviewer_id / reviewer_password\n- approver_id / approver_password\n- customer_token / reviewer_token / approver_token\n- app_id / txn_id / document_key\n",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "customer_id", "value": "customer-seed-001" },
    { "key": "customer_password", "value": "demo" },
    { "key": "reviewer_id", "value": "reviewer-seed-001" },
    { "key": "reviewer_password", "value": "demo" },
    { "key": "approver_id", "value": "approver-seed-001" },
    { "key": "approver_password", "value": "demo" },
    { "key": "customer_token", "value": "" },
    { "key": "reviewer_token", "value": "" },
    { "key": "approver_token", "value": "" },
    { "key": "app_id", "value": "" },
    { "key": "txn_id", "value": "" },
    { "key": "document_key", "value": "" }
  ],
  "item": [
    {
      "name": "Health",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{base_url}}/health",
              "host": ["{{base_url}}"],
              "path": ["health"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('status=ok', () => pm.expect(pm.response.json().status).to.eql('ok'));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register User",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"demo-new-user\",\n  \"password\": \"demo123\",\n  \"role\": \"CUSTOMER\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/register",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "register"]
            }
          }
        },
        {
          "name": "Login Customer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{customer_id}}\",\n  \"password\": \"{{customer_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('customer_token', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Reviewer",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{reviewer_id}}\",\n  \"password\": \"{{reviewer_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('reviewer_token', json.token);"
                ]
              }
            }
          ]
        },
        {
          "name": "Login Approver",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user_id\": \"{{approver_id}}\",\n  \"password\": \"{{approver_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/auth/login",
              "host": ["{{base_url}}"],
              "path": ["api", "auth", "login"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('approver_token', json.token);"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Customer",
      "item": [
        {
          "name": "Upload Document",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "body": {
              "mode": "formdata",
              "formdata": [
                {
                  "key": "file",
                  "type": "file",
                  "src": ""
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/api/customer/upload",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "upload"]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('document_key', json.key);"
                ]
              }
            }
          ]
        },
        {
          "name": "Submit Application",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const txnId = 'TXN-' + pm.variables.replaceIn('{{$randomUUID}}');",
                  "pm.collectionVariables.set('txn_id', txnId);"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "const json = pm.response.json();",
                  "pm.collectionVariables.set('app_id', json.application_id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"license_type\": \"TRADE_LICENSE\",\n  \"commodity\": {\n    \"name\": \"General Trading\",\n    \"description\": \"Import and export of consumer goods\",\n    \"category\": \"Commerce\"\n  },\n  \"documents\": [\n    {\n      \"name\": \"Passport Copy\",\n      \"url\": \"{{document_key}}\",\n      \"content_type\": \"application/pdf\"\n    }\n  ],\n  \"payment\": {\n    \"amount\": 500.00,\n    \"currency\": \"USD\",\n    \"transaction_id\": \"{{txn_id}}\"\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/customer/applications",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "applications"]
            }
          }
        },
        {
          "name": "List My Applications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/customer/applications",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "applications"]
            }
          }
        },
        {
          "name": "Get Application",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/customer/applications/{{app_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "applications", "{{app_id}}"]
            }
          }
        },
        {
          "name": "Update Application",
          "request": {
            "method": "PUT",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"commodity\": {\n    \"name\": \"General Trading Updated\",\n    \"description\": \"Updated description\",\n    \"category\": \"Commerce\"\n  },\n  \"documents\": [\n    {\n      \"name\": \"Passport Copy\",\n      \"url\": \"{{document_key}}\",\n      \"content_type\": \"application/pdf\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/customer/applications/{{app_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "applications", "{{app_id}}"]
            }
          }
        },
        {
          "name": "Resubmit Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"commodity\": {\n    \"name\": \"General Trading\",\n    \"description\": \"Resubmitted description\",\n    \"category\": \"Commerce\"\n  },\n  \"documents\": [\n    {\n      \"name\": \"Passport Copy\",\n      \"url\": \"{{document_key}}\",\n      \"content_type\": \"application/pdf\"\n    }\n  ]\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/customer/applications/{{app_id}}/resubmit",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "applications", "{{app_id}}", "resubmit"]
            }
          }
        },
        {
          "name": "Cancel Application",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/customer/applications/{{app_id}}/cancel",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "applications", "{{app_id}}", "cancel"]
            }
          }
        },
        {
          "name": "Delete Application",
          "request": {
            "method": "DELETE",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/customer/applications/{{app_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "customer", "applications", "{{app_id}}"]
            }
          }
        }
      ]
    },
    {
      "name": "Documents",
      "item": [
        {
          "name": "View Document (Customer Token)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{customer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/documents/view?key={{document_key}}",
              "host": ["{{base_url}}"],
              "path": ["api", "documents", "view"],
              "query": [
                { "key": "key", "value": "{{document_key}}" }
              ]
            }
          }
        }
      ]
    },
    {
      "name": "Reviewer",
      "item": [
        {
          "name": "List Queue",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{reviewer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/reviewer/applications",
              "host": ["{{base_url}}"],
              "path": ["api", "reviewer", "applications"]
            }
          }
        },
        {
          "name": "Get Application",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{reviewer_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/reviewer/applications/{{app_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "reviewer", "applications", "{{app_id}}"]
            }
          }
        },
        {
          "name": "Take Action (ACCEPT)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{reviewer_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"ACCEPT\",\n  \"notes\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/reviewer/applications/{{app_id}}/action",
              "host": ["{{base_url}}"],
              "path": ["api", "reviewer", "applications", "{{app_id}}", "action"]
            }
          }
        }
      ]
    },
    {
      "name": "Approver",
      "item": [
        {
          "name": "List Queue",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{approver_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/approver/applications",
              "host": ["{{base_url}}"],
              "path": ["api", "approver", "applications"]
            }
          }
        },
        {
          "name": "Get Application",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Authorization", "value": "Bearer {{approver_token}}" }
            ],
            "url": {
              "raw": "{{base_url}}/api/approver/applications/{{app_id}}",
              "host": ["{{base_url}}"],
              "path": ["api", "approver", "applications", "{{app_id}}"]
            }
          }
        },
        {
          "name": "Take Action (APPROVE)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{approver_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"action\": \"APPROVE\",\n  \"notes\": \"\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": {
              "raw": "{{base_url}}/api/approver/applications/{{app_id}}/action",
              "host": ["{{base_url}}"],
              "path": ["api", "approver", "applications", "{{app_id}}", "action"]
            }
          }
        }
      ]
    }
  ]
}
